{
  "name": "@suwa/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schemas-types": {
      "default": "./src/schemas-types/index.ts"
    },
    "./schemas-types/*": {
      "default": "./src/schemas-types/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:local": "bun run scripts/setup-local.ts",
    "db:setup": "bun run db:generate && bun run db:local",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "0.15.15",
    "@suwa/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "libsql": "0.5.22",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@suwa/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "^6"
  }
}
